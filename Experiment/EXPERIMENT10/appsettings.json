{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "CachingLoggingDemo": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "TimestampFormat": "[yyyy-MM-dd HH:mm:ss.fff] ",
        "SingleLine": true,
        "IncludeScopes": false,
        "UseUtcTimestamp": false
      }
    }
  },
  "AllowedHosts": "*"
}
