@{
    ViewData["Title"] = "Home — Caching & Logging Demo";
}

<div class="text-center py-5">
    <h1 style="font-weight:700; font-size:2.5rem;">
        <span style="background:linear-gradient(135deg,#6366f1,#06b6d4);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            ASP.NET Core Logging &amp; In-Memory Caching
        </span>
    </h1>
    <p class="mt-3" style="color:var(--text-secondary); font-size:1.1rem; max-width:700px; margin:0 auto;">
        This application demonstrates how <strong style="color:#6366f1">ILogger</strong> provides structured monitoring
        and how <strong style="color:#06b6d4">IMemoryCache</strong> dramatically improves performance by caching expensive data operations.
    </p>
</div>

<!-- Feature cards -->
<div class="row g-4 mt-2">
    <!-- Logging Card -->
    <div class="col-md-4">
        <div class="glass-card h-100">
            <div style="font-size:2rem; margin-bottom:0.5rem;">📝</div>
            <h5 style="font-weight:600;">Structured Logging</h5>
            <p style="color:var(--text-secondary); font-size:0.9rem;">
                Every controller action logs <code>Information</code>, <code>Warning</code>, and <code>Error</code>
                messages via <code>ILogger&lt;T&gt;</code>. Timestamps are printed in the console for easy monitoring.
            </p>
            <span class="badge-glow badge-source">ILogger&lt;T&gt;</span>
        </div>
    </div>
    <!-- Caching Card -->
    <div class="col-md-4">
        <div class="glass-card h-100">
            <div style="font-size:2rem; margin-bottom:0.5rem;">⚡</div>
            <h5 style="font-weight:600;">In-Memory Caching</h5>
            <p style="color:var(--text-secondary); font-size:0.9rem;">
                First request: ~2 seconds (simulated DB call). Subsequent requests: &lt;1ms from cache.
                Cache expires after <strong>60 seconds</strong> (absolute) or <strong>30 seconds</strong> idle.
            </p>
            <span class="badge-glow badge-cache">IMemoryCache</span>
        </div>
    </div>
    <!-- Swagger Card -->
    <div class="col-md-4">
        <div class="glass-card h-100">
            <div style="font-size:2rem; margin-bottom:0.5rem;">📄</div>
            <h5 style="font-weight:600;">Swagger API Docs</h5>
            <p style="color:var(--text-secondary); font-size:0.9rem;">
                All API endpoints are documented via Swagger / OpenAPI.
                Try the endpoints live and observe cache behaviour in the JSON responses.
            </p>
            <a href="/swagger" target="_blank" class="btn btn-primary-custom btn-sm mt-2">Open Swagger UI →</a>
        </div>
    </div>
</div>

<!-- How It Works -->
<div class="glass-card mt-5">
    <h4 style="font-weight:600;">🔄 How It Works</h4>
    <div class="row mt-3">
        <div class="col-md-6">
            <h6 style="color:var(--warning); font-weight:600;">First Request (Cache MISS)</h6>
            <ol style="color:var(--text-secondary); font-size:0.9rem;">
                <li>Controller checks <code>IMemoryCache</code> — key not found</li>
                <li>Fetches data from simulated source (~2s delay)</li>
                <li>Stores result in cache with 60s TTL</li>
                <li>Logs: <code style="color:#f59e0b">CACHE MISS</code> + elapsed time</li>
            </ol>
        </div>
        <div class="col-md-6">
            <h6 style="color:var(--success); font-weight:600;">Subsequent Requests (Cache HIT)</h6>
            <ol style="color:var(--text-secondary); font-size:0.9rem;">
                <li>Controller checks <code>IMemoryCache</code> — key found!</li>
                <li>Returns cached data instantly (&lt;1ms)</li>
                <li>No data source call needed</li>
                <li>Logs: <code style="color:#22c55e">CACHE HIT</code> + elapsed time</li>
            </ol>
        </div>
    </div>
</div>

<div class="text-center mt-4">
    <a asp-controller="Product" asp-action="Index" class="btn btn-primary-custom btn-lg">
        📦 Try the Products Page →
    </a>
</div>
